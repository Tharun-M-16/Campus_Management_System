    "description": "Sample Postman collection for the campus notifications microservice."
  },
  "item": [
    {
      "name": "Get all notifications",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://4.224.186.213/evaluation-service/notifications?limit=8&page=1",
          "protocol": "http",
          "host": ["4.224.186.213"],
